PORT=4000

# Modo de dados: "mock" usa dados de exemplo embutidos; "sheets" busca no Google Sheets real
DATA_SOURCE=mock

# Necessario apenas quando DATA_SOURCE=sheets
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
SHEET_ID=
SHEET_RANGE_REALIZADO=Realizado!A:Z
SHEET_RANGE_PLANEJAMENTO=Planejamento!A:Z

# Cloudinary - hospedagem das imagens dos criativos (pagina Analise por Criativo)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CREATIVES_FOLDER=criativos-senado
